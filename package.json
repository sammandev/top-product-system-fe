{
  "name": "ast-tools-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"if (!process.env.npm_config_user_agent?.startsWith('pnpm/')) { console.error('Use pnpm: corepack enable && pnpm install'); process.exit(1); }\"",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "docs:primevue": "node scripts/sync-primevue-docs.mjs",
    "lint": "biome check . --diagnostic-level=warn",
    "lint:fix": "biome check . --write",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "type-check": "vue-tsc -b --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@primeuix/themes": "^2.0.3",
    "@sentry/vue": "^10.45.0",
    "@tanstack/vue-query": "^5.99.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "exceljs": "^4.4.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "katex": "^0.16.40",
    "lodash-es": "^4.17.23",
    "npm-check-updates": "^19.6.5",
    "pinia": "^3.0.4",
    "pnpm": "^10.32.1",
    "primevue": "^4.5.5",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "happy-dom": "^20.8.4",
    "msw": "^2.12.14",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.3",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "glob": "^13.0.6",
    "minimatch": "^10.2.2"
  },
  "packageManager": "pnpm@10.32.1"
}
