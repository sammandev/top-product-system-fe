# API Base URL - Use empty string since code already includes /api prefix
# Nginx forwards /api/* to backend
VITE_API_BASE_URL=
VITE_API_URL=http://172.18.220.56:7070
VITE_DUT_API_BASE_URL=http://172.18.220.56:9001
VITE_ENVIRONMENT=production

VITE_APP_TITLE=Loading..
# VITE_APP_VERSION=1.0.0

VITE_ENABLE_ANALYTICS=false
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0

# Sentry (Optional - frontend error tracking)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# External API login for Guest user
VITE_GUEST_API_USERNAME=
VITE_GUEST_API_PASSWORD=

# CORS Configuration for Frontend
VITE_CORS_ORIGINS=http://172.18.220.56:7070,http://10.176.33.89:32678,http://localhost:3000,http://0.0.0.0:3000
VITE_IPLAS_API_TIMEOUT=120 # seconds

# Frontend Specific Logging
# VITE_LOG_LEVEL=WARNING